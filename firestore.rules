rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // HELPER FUNCTIONS
    // ==========================================
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'navodhayamlibraryamarakuni@gmail.com' || 
        request.auth.token.email.matches('.*@navodhayam-library\\.firebaseapp\\.com')
      );
    }

    function isOwner(data) {
      return request.auth != null && (
        request.auth.uid == data.uid || 
        request.auth.token.email == data.email ||
        request.auth.token.email == data.userEmail
      );
    }

    // ==========================================
    // SCHEMA VALIDATION
    // ==========================================

    function isValidBook(data) {
      return data.title is string && data.title.size() >= 2 &&
             data.author is string && data.author.size() >= 2 &&
             data.category is string &&
             data.available is bool;
    }

    function isValidMember(data) {
      return data.name is string && data.name.size() >= 3 &&
             data.phone is string && data.phone.matches('^[0-9+ ]{10,15}$') &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (data.vitalStatus == null || data.vitalStatus in ['Active', 'Deceased']);
    }

    function isValidRequest(data) {
      return data.bookId is string &&
             data.bookTitle is string &&
             data.status in ['pending', 'borrowed', 'returned', 'rejected'];
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    match /books/{bookId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidBook(request.resource.data);
      allow update: if isAdmin() || (canUpdateCoverOnly() && isValidBook(request.resource.data));
    }

    function canUpdateCoverOnly() {
      return request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['coverImageBase64', 'coverUpdatedAt']);
    }

    match /members/{memberId} {
      allow create: if request.auth != null && isValidMember(request.resource.data);
      allow get: if isAdmin() || isOwner(resource.data);
      allow list: if isAdmin();
      allow update, delete: if isAdmin() && isValidMember(request.resource.data);
    }

    match /requests/{requestId} {
      allow create: if request.auth != null && isValidRequest(request.resource.data);
      allow read: if isAdmin() || isOwner(resource.data);
      allow update, delete: if isAdmin() && isValidRequest(request.resource.data);
    }

    match /system_logs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

